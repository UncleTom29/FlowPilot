# Flow Cadence account used for contract deployment.
# Keep real credentials in the ignored flow-tester.private.json or .env.
FLOW_TESTNET_ACCOUNT_NAME=flow-tester
FLOW_TESTNET_ADDRESS=
FLOW_TESTNET_KEY=
FLOW_CONTRACT_ADDRESS=

# Flow dashboard seed
FLOW_DASHBOARD_STREAM_ID=default
FLOW_DASHBOARD_INITIAL_DEPOSIT=600.00000000
FLOW_DASHBOARD_ADDITIONAL_PRINCIPAL=180.00000000
FLOW_DASHBOARD_SALARY_RATE=0.00077200
FLOW_DASHBOARD_ELAPSED_SECONDS=15552000.0
FLOW_DASHBOARD_HARVESTED_YIELD=24.50000000
FLOW_DASHBOARD_LOTTERY_ID=primary-pool
FLOW_DASHBOARD_PORTFOLIO_ID=core-portfolio

# Flow EVM
EVM_RPC_URL=https://testnet.evm.nodes.onflow.org
EVM_DEPLOYER_PRIVATE_KEY=
AI_ORACLE_PUBLIC_KEY=
EVM_ORACLE_AGGREGATOR_ADDRESS=
EVM_WORK_PROOF_VERIFIER_ADDRESS=

# LLM providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_FALLBACK_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=FlowPilot

# Backend
BACKEND_PORT=3001
CORS_ALLOWED_ORIGINS=

# Frontend (Vite)
VITE_BACKEND_URL=http://localhost:3001
VITE_FLOW_NETWORK=testnet
VITE_FLOW_CONTRACT_ADDRESS=
VITE_FLOW_DASHBOARD_ACCOUNT_ADDRESS=
VITE_FLOW_DASHBOARD_STREAM_ID=default
VITE_FLOW_DASHBOARD_LOTTERY_ID=primary-pool
VITE_FLOW_DASHBOARD_PORTFOLIO_ID=core-portfolio
VITE_FLOW_DASHBOARD_SALARY_RATE=0.00077200
