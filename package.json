{
  "name": "flowpilot",
  "private": true,
  "workspaces": ["frontend", "backend"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "deploy:emulator": "flow project deploy --network=emulator",
    "deploy:testnet": "flow project deploy --network=testnet",
    "deploy:evm": "npx hardhat run evm/scripts/deployOracle.ts --network flowTestnet",
    "test": "jest --testPathPattern=tests/",
    "emulator": "flow emulator start"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "@onflow/flow-js-testing": "^0.3.5",
    "hardhat": "^2.22.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.2",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "@types/jest": "^29.5.12"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    }
  }
}
